# YooKassa — тестовые ключи на время разработки
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Supabase — только для базы данных (products, orders, download_tokens)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Beget S3 — хранилище файлов
S3_ENDPOINT=https://s3.ru1.storage.beget.cloud
S3_BUCKET=750740e55ba3-diskn8n
S3_REGION=ru-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# SMTP для email
SMTP_HOST=smtp.timeweb.ru
SMTP_PORT=465
SMTP_USER=info@mishka-max.ru
SMTP_PASSWORD=
SMTP_FROM="Мишка Макс <info@mishka-max.ru>"

# Lava Top — оплата картами Visa/Mastercard не из РФ
# API key: https://app.lava.top/integrations/public-api
LAVA_API_KEY=
# UUID оффера (цены) — должен поддерживать ту же валюту, что LAVA_CURRENCY
LAVA_OFFER_ID=
# USD или EUR для иностранных карт; RUB — только если оффер в рублях (МИР/РФ карты)
LAVA_CURRENCY=USD
# Курс: сколько рублей за 1 USD (для пересчёта суммы корзины в USD)
LAVA_RUB_PER_USD=95
# true — передавать сумму корзины в amount (нужен оффер с динамической ценой)
LAVA_DYNAMIC_PRICE=true
# MONTHLY — если LAVA_OFFER_ID от подписки, иначе не указывать
# LAVA_PERIODICITY=MONTHLY
# Ключ, который вы задаёте в настройках webhook в Lava (тип: API key вашего сервиса)
LAVA_WEBHOOK_API_KEY=

# Robokassa — оплата иностранными картами (кабинет: https://partner.robokassa.ru)
ROBOKASSA_MERCHANT_LOGIN=
ROBOKASSA_PASSWORD1=
ROBOKASSA_PASSWORD2=
# 1 — тестовый режим (платежи не списываются), не ставить в проде
ROBOKASSA_TEST_MODE=

# Публичный URL сайта (обязателен для возврата с Lava/Robokassa на /thank-you после оплаты)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Админ-панель
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# Автоматическая рассылка через 7 дней после покупки
# Секрет для защиты cron-эндпоинта
CRON_SECRET=your-cron-secret-here
# PDF-письмо задаётся для каждой серии в админке → карточка товара → «Письмо Мишки Макса»
